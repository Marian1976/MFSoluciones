<script>
function setNav(el, panel) {
  document.querySelectorAll('.nav-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.panel[id^="panel-"]').forEach(p=>{
    if(!p.id.includes('-cat') && !p.id.includes('-ventas')) p.classList.remove('active');
  });
  var titles = {dashboard:'Dashboard general',clientes:'Clientes y soporte',flujos:'Catálogo de flujos n8n',hardware:'Hardware & IA local',webhooks:'Webhooks y automatización',sql:'Modelo de datos SQL'};
  document.getElementById('panel-'+panel).classList.add('active');
  document.getElementById('topbar-title').textContent = titles[panel]||panel;
  if(panel==='flujos'){
    document.getElementById('panel-flujos-cat').classList.add('active');
    document.getElementById('panel-flujos-ventas').classList.remove('active');
  }
}
function setSubtab(el, id) {
  el.closest('.panel').querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['flujos-cat','flujos-ventas'].forEach(p=>{
    var el2=document.getElementById('panel-'+p);
    if(el2) el2.classList.remove('active');
  });
  document.getElementById('panel-'+id).classList.add('active');
}
</script>
