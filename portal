
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;500;600&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --mf-bg:#0a0e17;
  --mf-surface:#111827;
  --mf-card:#161e2e;
  --mf-border:#1e2d45;
  --mf-accent:#00d4ff;
  --mf-accent2:#7c3aed;
  --mf-green:#10b981;
  --mf-amber:#f59e0b;
  --mf-red:#ef4444;
  --mf-text:#e2e8f0;
  --mf-muted:#64748b;
  --mf-mono:'JetBrains Mono',monospace;
  --mf-sans:'Sora',sans-serif;
}
body{background:var(--mf-bg);color:var(--mf-text);font-family:var(--mf-sans);font-size:13px;line-height:1.5}
.shell{display:flex;height:600px;overflow:hidden;border-radius:12px;border:1px solid var(--mf-border)}
/* Sidebar */
.sidebar{width:200px;background:var(--mf-surface);border-right:1px solid var(--mf-border);display:flex;flex-direction:column;flex-shrink:0}
.brand{padding:16px;border-bottom:1px solid var(--mf-border)}
.brand-name{font-size:14px;font-weight:600;color:var(--mf-accent);letter-spacing:.5px}
.brand-sub{font-size:10px;color:var(--mf-muted);font-family:var(--mf-mono);margin-top:2px}
.nav{padding:8px 0;flex:1}
.nav-item{display:flex;align-items:center;gap:8px;padding:9px 16px;cursor:pointer;border-left:3px solid transparent;transition:all .15s;color:var(--mf-muted);font-size:12px}
.nav-item:hover{background:rgba(0,212,255,.04);color:var(--mf-text)}
.nav-item.active{border-left-color:var(--mf-accent);background:rgba(0,212,255,.07);color:var(--mf-accent)}
.nav-icon{width:14px;height:14px;opacity:.8}
.nav-section{padding:16px 16px 4px;font-size:9px;letter-spacing:1px;color:var(--mf-muted);text-transform:uppercase;font-family:var(--mf-mono)}
.sidebar-footer{padding:12px;border-top:1px solid var(--mf-border)}
.user-chip{display:flex;align-items:center;gap:8px}
.avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--mf-accent2),var(--mf-accent));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;flex-shrink:0}
.user-info{min-width:0}
.user-name{font-size:11px;font-weight:500;color:var(--mf-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.user-role{font-size:10px;color:var(--mf-accent);font-family:var(--mf-mono)}
/* Main */
.main{flex:1;overflow:hidden;display:flex;flex-direction:column}
.topbar{padding:12px 20px;border-bottom:1px solid var(--mf-border);display:flex;align-items:center;justify-content:space-between;background:var(--mf-surface)}
.topbar-title{font-size:14px;font-weight:500}
.topbar-right{display:flex;align-items:center;gap:8px}
.badge{padding:3px 8px;border-radius:20px;font-size:10px;font-family:var(--mf-mono)}
.badge-cyan{background:rgba(0,212,255,.12);color:var(--mf-accent);border:1px solid rgba(0,212,255,.2)}
.badge-green{background:rgba(16,185,129,.12);color:var(--mf-green);border:1px solid rgba(16,185,129,.2)}
.badge-amber{background:rgba(245,158,11,.12);color:var(--mf-amber);border:1px solid rgba(245,158,11,.2)}
.badge-red{background:rgba(239,68,68,.12);color:var(--mf-red);border:1px solid rgba(239,68,68,.2)}
.badge-purple{background:rgba(124,58,237,.12);color:#a78bfa;border:1px solid rgba(124,58,237,.2)}
.content{flex:1;overflow-y:auto;padding:16px 20px}
/* Tabs */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--mf-border);margin-bottom:16px}
.tab{padding:8px 14px;cursor:pointer;font-size:12px;color:var(--mf-muted);border-bottom:2px solid transparent;transition:all .15s}
.tab:hover{color:var(--mf-text)}
.tab.active{color:var(--mf-accent);border-bottom-color:var(--mf-accent)}
/* Panels */
.panel{display:none}
.panel.active{display:block}
/* Stats row */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.stat-card{background:var(--mf-card);border:1px solid var(--mf-border);border-radius:8px;padding:12px 14px}
.stat-label{font-size:10px;color:var(--mf-muted);font-family:var(--mf-mono);text-transform:uppercase;letter-spacing:.5px}
.stat-value{font-size:22px;font-weight:600;margin-top:4px;font-family:var(--mf-mono)}
.stat-value.cyan{color:var(--mf-accent)}
.stat-value.green{color:var(--mf-green)}
.stat-value.amber{color:var(--mf-amber)}
.stat-value.purple{color:#a78bfa}
.stat-sub{font-size:10px;color:var(--mf-muted);margin-top:2px}
/* Cards */
.card{background:var(--mf-card);border:1px solid var(--mf-border);border-radius:8px;margin-bottom:10px;overflow:hidden}
.card-header{padding:10px 14px;border-bottom:1px solid var(--mf-border);display:flex;align-items:center;justify-content:space-between}
.card-title{font-size:12px;font-weight:500;color:var(--mf-text)}
.card-body{padding:10px 14px}
/* Table */
.table{width:100%;border-collapse:collapse}
.table th{padding:8px 10px;text-align:left;font-size:10px;font-weight:500;color:var(--mf-muted);border-bottom:1px solid var(--mf-border);font-family:var(--mf-mono);text-transform:uppercase;letter-spacing:.5px}
.table td{padding:9px 10px;font-size:12px;border-bottom:1px solid rgba(30,45,69,.5);color:var(--mf-text)}
.table tr:last-child td{border-bottom:none}
.table tr:hover td{background:rgba(255,255,255,.02)}
/* Flujo cards */
.flujo-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.flujo-card{background:var(--mf-card);border:1px solid var(--mf-border);border-radius:8px;padding:14px;cursor:pointer;transition:border-color .15s;position:relative;overflow:hidden}
.flujo-card:hover{border-color:var(--mf-accent)}
.flujo-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.flujo-card.msg::before{background:linear-gradient(90deg,var(--mf-accent),var(--mf-accent2))}
.flujo-card.trading::before{background:linear-gradient(90deg,var(--mf-amber),var(--mf-red))}
.flujo-name{font-size:13px;font-weight:500;margin-bottom:4px}
.flujo-desc{font-size:11px;color:var(--mf-muted);margin-bottom:10px;line-height:1.4}
.flujo-meta{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
/* Hardware cards */
.hw-card{background:var(--mf-card);border:1px solid var(--mf-border);border-radius:8px;padding:14px;margin-bottom:10px}
.hw-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.hw-name{font-size:13px;font-weight:500}
.spec-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.spec-item{background:rgba(255,255,255,.03);border-radius:4px;padding:6px 8px}
.spec-key{font-size:10px;color:var(--mf-muted);font-family:var(--mf-mono)}
.spec-val{font-size:11px;font-weight:500;margin-top:1px}
/* Log / bitácora */
.log-entry{padding:8px 10px;border-bottom:1px solid rgba(30,45,69,.5);display:flex;gap:10px;align-items:flex-start}
.log-entry:last-child{border-bottom:none}
.log-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px}
.log-dot.green{background:var(--mf-green)}
.log-dot.amber{background:var(--mf-amber)}
.log-dot.cyan{background:var(--mf-accent)}
.log-text{font-size:11px;color:var(--mf-text);line-height:1.4}
.log-time{font-size:10px;color:var(--mf-muted);font-family:var(--mf-mono);margin-top:2px}
/* Tickets */
.ticket{padding:10px 14px;border-bottom:1px solid rgba(30,45,69,.5);cursor:pointer;transition:background .1s}
.ticket:hover{background:rgba(255,255,255,.02)}
.ticket:last-child{border-bottom:none}
.ticket-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.ticket-title{font-size:12px;font-weight:500}
.ticket-meta{font-size:10px;color:var(--mf-muted)}
/* Progress bar */
.pbar{height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden;margin-top:6px}
.pbar-fill{height:100%;border-radius:2px;transition:width .3s}
/* Status dot */
.dot{width:7px;height:7px;border-radius:50%;display:inline-block;flex-shrink:0}
.dot-green{background:var(--mf-green)}
.dot-amber{background:var(--mf-amber)}
.dot-red{background:var(--mf-red)}
/* Webhook row */
.wh-row{padding:8px 10px;border-bottom:1px solid rgba(30,45,69,.5);display:grid;grid-template-columns:20px 1fr 80px 70px;gap:8px;align-items:center;font-size:11px}
.wh-row:last-child{border-bottom:none}
/* Mini chart bars */
.chart-row{display:flex;gap:3px;align-items:flex-end;height:40px;margin-top:8px}
.bar{flex:1;border-radius:2px 2px 0 0;background:rgba(0,212,255,.3);transition:background .2s;cursor:pointer}
.bar:hover{background:var(--mf-accent)}
/* Quick actions */
.actions{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
.action-btn{background:var(--mf-card);border:1px solid var(--mf-border);border-radius:8px;padding:10px 12px;cursor:pointer;font-family:var(--mf-sans);font-size:11px;color:var(--mf-muted);text-align:left;transition:all .15s;display:flex;align-items:center;gap:8px}
.action-btn:hover{border-color:var(--mf-accent);color:var(--mf-accent);background:rgba(0,212,255,.04)}
.action-icon{font-size:14px}
/* SQL panel */
.sql-block{background:#0d1117;border:1px solid var(--mf-border);border-radius:6px;padding:10px 12px;font-family:var(--mf-mono);font-size:10px;line-height:1.8;overflow-x:auto;white-space:pre}
.kw{color:#ff7b72}.fn{color:var(--mf-accent)}.cm{color:var(--mf-muted)}.str{color:#a5d6ff}.num{color:var(--mf-amber)}
/* Scroll */
.content::-webkit-scrollbar{width:4px}
.content::-webkit-scrollbar-track{background:transparent}
.content::-webkit-scrollbar-thumb{background:var(--mf-border);border-radius:2px}
/* Responsive override for narrow widget */
@media(max-width:520px){.stats{grid-template-columns:1fr 1fr}.flujo-grid{grid-template-columns:1fr}}
</style>

